# =====================================================================
# Voice AI Agent — reference of all tunable settings.
#
# IMPORTANT: the agent reads `config/settings.py`, NOT this file. This is
# provided as a single-page cheat sheet of everything you can tweak. To
# change a value, edit the corresponding line in `config/settings.py`.
# =====================================================================

# ---------- Speech-to-text -------------------------------------------
# Backend: "whisper" (faster-whisper, far more accurate) or "vosk" (light).
STT_BACKEND=whisper
# Whisper model size (downloaded on first run, cached under ~/.cache).
# Sizes: tiny.en (~75MB), base.en (~145MB), small.en (~485MB), medium.en (~1.5GB).
WHISPER_MODEL_SIZE=base.en
# Compute type: int8 (CPU friendly), float16 (GPU), float32 (max quality).
WHISPER_COMPUTE_TYPE=int8
# Vosk fallback (used when STT_BACKEND=vosk).
VOSK_MODEL_NAME=vosk-model-small-en-us-0.15
SAMPLE_RATE=16000
AUDIO_BLOCKSIZE=8000

# ---------- LLM intent fallback (Groq, free tier) --------------------
# When the regex-based intent recogniser returns "unknown", the agent can
# fall back to a small LLM hosted by Groq (free tier, ~14k req/day).
# 1) Sign up at https://console.groq.com (free, no credit card)
# 2) Create a key at https://console.groq.com/keys
# 3) Paste it below. Leave blank to disable the LLM fallback.
GROQ_API_KEY=your_groq_api_key_here
# llama-3.1-8b-instant is fast & free. Other options on console.groq.com.
LLM_MODEL=llama-3.1-8b-instant

# ---------- Text-to-speech (pyttsx3 / SAPI5) -------------------------
# Words per minute. 150 = slow, 185 = natural, 220 = fast.
TTS_RATE=185
# 0.0 – 1.0
TTS_VOLUME=1.0
# Partial match against installed voice names. Examples on Windows:
# "Zira" (female US), "David" (male US), "Mark" (male US). Empty = default.
TTS_VOICE_HINT=

# ---------- Wake word / listening mode -------------------------------
# False = always-listen (default). True = only act when the phrase begins
# with one of WAKE_WORDS.
REQUIRE_WAKE_WORD=False
# Comma-separated. Case-insensitive.
WAKE_WORDS=replica,hey replica,hello replica,jarvis,friday,agent,assistant

# ---------- Floating UI ----------------------------------------------
UI_ALWAYS_ON_TOP=True
# 1.0 = fully opaque, 0.85 = noticeably translucent.
UI_OPACITY=0.95

# ---------- Output paths (Windows expansion supported) ---------------
RESULT_FILE=%USERPROFILE%\Documents\result.txt
SCREENSHOT_DIR=%USERPROFILE%\Pictures\VoiceAgent
# Relative paths are resolved from the project root.
HISTORY_FILE=data/history.jsonl
LOGS_DIR=logs

# ---------- Catalogues (edit in settings.py — lists don't fit in .env) --
# APP_COMMANDS      — spoken name -> argv list (e.g. "chrome": chrome.exe path)
# FOLDER_PATHS      — spoken name -> Path (e.g. "documents": ~/Documents)
# WEBSITE_SHORTCUTS — spoken name -> URL (e.g. "youtube": https://youtube.com)
# See config/settings.py for the full, editable tables.
